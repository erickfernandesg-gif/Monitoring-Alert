# URL base da sua aplicação (ex: ambiente de produção ou localhost)
APP_URL=http://localhost:3000

# Segredo para autenticar requisições na rota /api/cron/process-alerts
CRON_SECRET=sua_chave_super_segura_aqui

# (Opcional) Configurações de SMTP que foram baseadas nas alterações
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=seu_usuario
SMTP_PASS=sua_senha
SMTP_FROM='"Humanitarian Ops" <alerts@humanitarian.org>'
SMTP_NOREPLY='"Equipe de Alertas" <noreply@sistemadealertas.com>'